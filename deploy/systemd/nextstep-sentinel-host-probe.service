[Unit]
Description=Nextstep Sentinel host probe
After=docker.service

[Service]
Type=oneshot
User=root
Group=root
WorkingDirectory=/opt/nextstep-dashboard
ExecStart=/opt/nextstep-dashboard/deploy/host-probe.sh /opt/nextstep-dashboard/deploy/.env.production
PrivateTmp=true
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/run/nextstep-dashboard
