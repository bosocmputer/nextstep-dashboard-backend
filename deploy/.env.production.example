DASHBOARD_DOMAIN=dashboard.nextstep-soft.com
BACKEND_SHA=
FRONTEND_SHA=
# Keep loopback when Cloudflare Tunnel or the reverse proxy runs on this host.
# Set 0.0.0.0 only when an external gateway must reach port 6324, then firewall it.
FRONTEND_BIND_ADDRESS=127.0.0.1

# Generate POSTGRES_PASSWORD with `openssl rand -hex 32`, then put the same
# URL-safe value in DATABASE_URL. Do not use the literal placeholder below.
POSTGRES_DB=nextstep
POSTGRES_USER=nextstep
POSTGRES_PASSWORD=
DATABASE_URL=postgres://nextstep:REPLACE_WITH_POSTGRES_PASSWORD@postgres:5432/nextstep?sslmode=verify-full&sslrootcert=/run/secrets/postgres-root.crt
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=2

ADMIN_USERNAME=superadmin
# Keep the generated Argon2id hash inside literal single quotes. Docker Compose
# otherwise treats the hash's dollar signs as variable interpolation.
ADMIN_PASSWORD_HASH=
SESSION_HMAC_KEY=
ENCRYPTION_MASTER_KEY=
ENCRYPTION_KEY_ID=key-2026-01

SML_ALLOWED_CIDRS=10.0.0.0/8,192.168.0.0/16
SML_ALLOWED_HOSTS=
# Allow customer-owned public DNS hostnames without maintaining one hostname
# entry per shop. Private/raw IP endpoints still require SML_ALLOWED_CIDRS.
SML_ALLOW_PUBLIC_ENDPOINTS=true
SML_ALLOWED_PORTS=*
REPORT_WORKER_CONCURRENCY=4
DELIVERY_WORKER_CONCURRENCY=4
REPORT_GLOBAL_QUERY_CONCURRENCY=4
REPORT_HOST_QUERY_CONCURRENCY=2

# Keep all query/cache capabilities disabled for the initial deployment. Enable
# them in the staged order documented in RUNBOOK.md.
SUMMARY_QUERY_ENABLED=false
GENERATION_CACHE_ENABLED=false
STALE_REVALIDATION_ENABLED=false
HEAVY_CHUNK_ENABLED=false
# Comma-separated exact pairs: <tenant-uuid>/stock_balance or
# <tenant-uuid>/ar_customer_movement. Empty while HEAVY_CHUNK_ENABLED=false.
HEAVY_CHUNK_TENANT_REPORTS=
SCHEDULE_CHUNK_ENABLED=false

SNAPSHOT_FIRST_ENABLED=false
SNAPSHOT_FIRST_TENANT_IDS=
SMART_SCHEDULE_PERIODS_ENABLED=false
SMART_SCHEDULE_PERIOD_TENANT_IDS=

LINE_LOGIN_CHANNEL_ID=
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=
