APP_ENV=development
HTTP_ADDR=:8080
PUBLIC_BASE_URL=http://localhost:6324
DATABASE_URL=postgres://nextstep:change-me@localhost:5432/nextstep?sslmode=disable
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=2
ADMIN_USERNAME=superadmin
# Argon2id encoded hash only. Never put a plaintext password here.
ADMIN_PASSWORD_HASH=
# Base64 values. SESSION_HMAC_KEY >= 32 decoded bytes; ENCRYPTION_MASTER_KEY = 32 bytes.
SESSION_HMAC_KEY=
ENCRYPTION_MASTER_KEY=
ENCRYPTION_KEY_ID=key-2026-01
# Comma-separated private network ranges containing approved tenant SML endpoints.
SML_ALLOWED_CIDRS=10.0.0.0/8,192.168.0.0/16
SML_ALLOWED_HOSTS=
SML_ALLOW_PUBLIC_ENDPOINTS=true
SML_ALLOWED_PORTS=*
REPORT_WORKER_CONCURRENCY=4
DELIVERY_WORKER_CONCURRENCY=4
# DB-backed JavaWS admission limits. Keep per-tenant concurrency at one in code.
REPORT_GLOBAL_QUERY_CONCURRENCY=4
REPORT_HOST_QUERY_CONCURRENCY=2
SNAPSHOT_FIRST_ENABLED=false
# Optional comma-separated tenant UUID allowlist for a staged rollout. Empty means all tenants when enabled.
SNAPSHOT_FIRST_TENANT_IDS=
# Safe default for every tenant. Set false only as an emergency rollback.
SUMMARY_QUERY_ENABLED=true
GENERATION_CACHE_ENABLED=false
STALE_REVALIDATION_ENABLED=false
# Heavy chunking is opt-in twice: globally and by exact tenant UUID/report key pair.
HEAVY_CHUNK_ENABLED=false
HEAVY_CHUNK_TENANT_REPORTS=
# Keep schedule chunking disabled until its separate LINE/source-consistency gate passes.
SCHEDULE_CHUNK_ENABLED=false
SMART_SCHEDULE_PERIODS_ENABLED=false
SMART_SCHEDULE_PERIOD_TENANT_IDS=
LINE_LOGIN_CHANNEL_ID=
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=
